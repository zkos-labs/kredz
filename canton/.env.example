# Canton Network Validator — KREDZ
# Copy to .env and fill with your credentials

# ── Canton Validator Key ──
CANTON_VALIDATOR_KEY=

# ── Five North Sandbox (DevNet) — Recommended ──
# Get these from 5N after requesting access: https://forms.gle/AKJ79crekY5QsaUW7
FIVENORTH_CLIENT_ID=
FIVENORTH_CLIENT_SECRET=

# ── Five North Sandbox Endpoints ──
FIVENORTH_AUTH_URL=https://auth.sandbox.fivenorth.io
FIVENORTH_LEDGER_API=https://ledger-api.validator.devnet.sandbox.fivenorth.io
FIVENORTH_LEDGER_WS=wss://ledger-api.validator.devnet.sandbox.fivenorth.io

# ── API Token for legacy access ──
CANTON_API_TOKEN=

# ── Canton Foundation DevNet (requires VPN + SV sponsorship) ──
CANTON_SV_URL=https://sv.sv-1.dev.global.canton.network.sync.global
CANTON_PARTY_HINT=kredz-operator-1
