# ── Server ──
PORT=3001
NODE_ENV=development

# ── Midnight Network ──
MIDNIGHT_INDEXER_URL=http://localhost:9944/graphql
MIDNIGHT_NODE_URI=http://localhost:9944

# ── EVM RPC ──
BASE_RPC_URL=https://sepolia.base.org
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your-key

# ── Scoring Engine ──
SCORING_ENGINE_KEY=0x...  # ECDSA private key (hex) for signing score attestations
SCORING_ENGINE_PUBKEY=0x...  # Registered on Midnight and Base verifier

# ── SumSub (KYC) ──
SUMSUB_API_URL=https://api.sumsub.com
SUMSUB_APP_TOKEN=your-app-token
SUMSUB_SECRET_KEY=your-secret-key

# ── Chainalysis KYT ──
CHAINALYSIS_API_KEY=your-api-key

# ── Cardano Blockfrost ──
BLOCKFROST_API_KEY=your-project-id

# ── API Security ──
API_KEY_HASH=sha256-of-your-api-key  # pre-hashed for validation
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Canton Sync ──
CANTON_LEDGER_API_URL=http://localhost:3901
CANTON_JSON_API_URL=http://localhost:3975
