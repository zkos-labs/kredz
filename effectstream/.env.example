# EffectStream Node — kredz.xyz multichain sync engine
#
# Reads chain data from 5 networks and feeds them into a unified state machine
# that computes the KREDZ Score. Replaces the manual relayer/index.ts polling.
#
# Prerequisites: bun (https://bun.sh)
# Setup: bun install && bun run dev

# Midnight — ZK chain for score attestation
MIDNIGHT_INDEXER=http://localhost:8088/api/v1/graphql

# Base — EVM chain for SBT badge events
BASE_RPC=https://sepolia.base.org

# Cardano — partner chain for wallet history
CARDANO_CARP_URL=https://cardano-preview.blockfrost.io/api/v0
BLOCKFROST_API_KEY=your-project-id

# Solana — SVM chain for ScoreBadge PDA
SOLANA_RPC=https://api.devnet.solana.com

# Canton — institutional chain for KredzScore DAML
CANTON_LEDGER_API=http://localhost:3901
