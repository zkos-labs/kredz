# Frontend .env — DO NOT COMMIT

# ── Midnight (1AM Wallet) ──
# 'preprod' | 'preview' | 'mainnet'
VITE_MIDNIGHT_NETWORK=preprod

# ── Base (EVM) ──
# Fill after deploying with: forge script script/Deploy.s.sol --broadcast
VITE_VERIFIER_ADDRESS=
VITE_BADGE_ADDRESS=
VITE_BASE_RPC=https://sepolia.base.org

# ── Solana (SVM) ──
# Deployed program ID. Runs on devnet.
# Deploy with: solana program deploy target/deploy/kredz_score_badge.so
VITE_SOLANA_PROGRAM_ID=24KqR89h5SMLvV4QCKw4HAcYxVjovZU73SMyYvjETZ7E
VITE_SOLANA_RPC=https://api.devnet.solana.com

# ── Canton (DAML) ──
# Localnet: http://localhost:3975
# Testnet: requires SV sponsorship and participant node
VITE_CANTON_LEDGER_API=http://localhost:3975
VITE_CANTON_KREDZ_PARTY=kredz
